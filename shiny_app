server <- function(input, output, session) {
    # Data initialization
    load_data()

    app_state <- reactiveValues(
        current_month_range = get_prior_month_range(),
        saved_reviews = load_saved_reviews()
    )

    # Make activity_data reactive to always use latest saved reviews
    activity_data <- reactive({
        base_activity_data <- create_full_activity_data()
        merge_activity_with_reviews(base_activity_data, app_state$saved_reviews)
    })

    # Add filter trigger at top of server function (after reactiveValues)
    filter_trigger <- reactiveVal(0)

    # Force initial filter trigger
    observe({
        if (filter_trigger() == 0) {
            filter_trigger(1)
        }
    })

    # Unified data reactives
    enriched_activity_data <- reactive({
        req(activity_data())
        add_dollar_amounts(activity_data(),
                           input$high_dollar_threshold %||% CONFIG$default_high_threshold,
                           input$low_dollar_threshold %||% CONFIG$default_low_threshold)
    })


    monthly_filtered_data <- reactive({
        filter_trigger()

        data <- enriched_activity_data() %>%
            filter(cycle_date >= app_state$current_month_range$start & cycle_date <= app_state$current_month_range$end)

        if (input$activity_type != "all") data <- data %>% filter(activity_type == input$activity_type)
        if (input$review_status_filter != "all") data <- data %>% filter(review_status == input$review_status_filter)
        if (input$contract_search != "") data <- data %>% filter(grepl(input$contract_search, contract_id, ignore.case = TRUE))
        if (input$show_dollar_risks_only) data <- data %>% filter(dollar_risk %in% c("High Dollar", "Low Dollar"))

        # Amount filtering
        if (!is.null(input$min_amount) && !is.na(input$min_amount)) {
            data <- data %>% filter(amount >= input$min_amount)
        }
        if (!is.null(input$max_amount) && !is.na(input$max_amount)) {
            data <- data %>% filter(amount <= input$max_amount)
        }
        if (input$exclude_zero_amounts) {
            data <- data %>% filter(amount > 0)
        }

        if (input$poly_company != "all") {
            company_contracts <- policies %>%
                filter(Policy_Contract_Company == input$poly_company) %>%
                distinct(Policy_Contract_Number) %>% pull(Policy_Contract_Number)
            data <- data %>% filter(contract_id %in% company_contracts)
        }

        # Group by contract_id and activity_type, take most recent record per combination
        data <- data %>%
            arrange(desc(cycle_date)) %>%
            distinct(contract_id, activity_type, .keep_all = TRUE)

        data
    })


    get_all_completed_reviews <- reactive({
        req(app_state$saved_reviews)
        app_state$saved_reviews %>%
            filter(review_status == "Completed" & !is.na(quality_score)) %>%
            mutate(review_date = as.Date(review_date))
    })

    # Shared risk filter reactive
    risk_filtered_data <- eventReactive(input$apply_risk_filters, {
        historical_reviews <- get_historical_reviews()

        if (nrow(historical_reviews) == 0) return(historical_reviews)

        # Apply activity filter
        if (!is.null(input$risk_activity_filter) && !"all" %in% input$risk_activity_filter) {
            historical_reviews <- historical_reviews %>%
                filter(activity_type %in% input$risk_activity_filter)
        }

        # Apply month filter
        if (!is.null(input$risk_month_filter) && length(input$risk_month_filter) > 0) {
            selected_months <- as.Date(input$risk_month_filter)
            historical_reviews <- historical_reviews %>%
                filter(floor_date(as.Date(cycle_date), "month") %in% selected_months)
        }

        historical_reviews
    }, ignoreNULL = FALSE)

    # Month navigation


    # Month navigation observers
    month_buttons <- list(prev_month = -1, next_month = 1)
    for(button_name in names(month_buttons)) {
        local({
            direction <- month_buttons[[button_name]]
            button <- button_name
            observeEvent(input[[button]], {
                current_start <- app_state$current_month_range$start
                new_start <- current_start + months(direction)
                app_state$current_month_range <- list(start = new_start, end = ceiling_date(new_start, "month") - days(1))
                filter_trigger(filter_trigger() + 1)
            })
        })
    }

    observeEvent(input$apply_filters, {
        filter_trigger(filter_trigger() + 1)
    })

    output$current_month_display <- renderText({
        if (!is.null(app_state$pending_month_range)) {
            format(app_state$pending_month_range$start, "%B %Y")
        } else {
            format(app_state$current_month_range$start, "%B %Y")
        }
    })

    output$monthly_title <- renderText({
        paste("Items Requiring Review -", format(app_state$current_month_range$start, "%B %Y"))
    })

    # Value boxes
    create_value_boxes <- function(data) {
        list(
            total_items = valueBox(nrow(data), "Total Contracts", icon = icon("list"), color = "blue"),
            pending_items = valueBox(nrow(filter(data, review_status == "Pending Review")), "Pending Review", icon = icon("clock"), color = "aqua"),
            completed_items = valueBox(nrow(filter(data, review_status == "Completed")), "Completed Review", icon = icon("check"), color = "olive"),
            in_progress_items = valueBox(nrow(filter(data, review_status == "In Progress")), "Review In Progress", icon = icon("clock"), color = "yellow"),
            flagged_items = valueBox(nrow(filter(data, review_status == "Flagged")), "Flagged Items", icon = icon("exclamation-triangle"), color = "red"),
            dollar_risk_items = valueBox(nrow(filter(data, dollar_risk %in% c("High Dollar", "Low Dollar"))), "Dollar Risk Items", icon = icon("dollar-sign"), color = "purple")
        )
    }

    value_boxes <- reactive({ create_value_boxes(monthly_filtered_data()) })

    # Loop for standard value boxes
    observe({
        boxes <- value_boxes()
        for(box_name in names(boxes)) {
            local({
                name <- box_name
                output[[name]] <- renderValueBox({ boxes[[name]] })
            })
        }
    })

    # Special value boxes (these have custom logic)
    output$total_contracts_reviewed <- renderValueBox({
        completed_data <- get_all_completed_reviews()
        total_count <- nrow(completed_data)
        color <- if (total_count >= 100) "green" else if (total_count >= 50) "yellow" else "red"
        valueBox(value = total_count, subtitle = "Total Contracts Reviewed", icon = icon("file-check"), color = color)
    })
    # Main data table
    output$monthly_review_table <- DT::renderDataTable({
        data <- monthly_filtered_data() %>%
            select(
                'Contract ID' = contract_id,
                'Activity Type' = activity_type,
                'Cycle Date' = cycle_date,
                amount,
                'Dollar Risk' = dollar_risk,
                'Review Status' = review_status
            )

        dt_table <- DT::datatable(data, options = list(pageLength = 25, scrollX = TRUE, selection = 'single'), rownames = FALSE) %>%
            formatCurrency("amount", currency = "$", digits = 2) %>%
            formatStyle("Dollar Risk", backgroundColor = styleEqual(c("High Dollar", "Low Dollar"), c("#ffcccb", "#fffacd")))

        dt_table
    })

    # Contract details
    selected_row_data <- reactive({
        if (length(input$monthly_review_table_rows_selected) > 0) {
            return(monthly_filtered_data()[input$monthly_review_table_rows_selected, ])
        }
        NULL
    })

    output$selected_contract_header <- renderText({
        selected_row <- selected_row_data()
        if (!is.null(selected_row)) {
            person_info <- get_contract_names(selected_row$contract_id)
            paste("Contract:", selected_row$contract_id, "| Activity:", selected_row$activity_type, "| Owner:", person_info)
        }
    })

    get_detail_data <- function(selected_row) {
        activity_type <- selected_row$activity_type
        contract_id <- selected_row$contract_id

        detail_data <- switch(activity_type,
                              "transactions" = {
                                  transactions %>%
                                      filter(Transaction_Contract_Number == contract_id) %>%
                                      select(-matches("Transaction_TPA", ignore.case = TRUE))
                              },
                              "disbursements" = {
                                  disbursements %>%
                                      filter(Disbursement_Contract_Number == contract_id) %>%
                                      select(-matches("Disbursement_TPA", ignore.case = TRUE))
                              },
                              "claims" = {
                                  claims %>%
                                      filter(Claims_Contract_Number == contract_id) %>%
                                      select(-matches("Claims_TPA", ignore.case = TRUE))
                              },
                              "automated_activity" = {
                                  automated_activity %>%
                                      filter(Activity_Contract_Number == contract_id) %>%
                                      select(-matches("Activity_TPA", ignore.case = TRUE))
                              },
                              "policies" = {
                                  policies %>%
                                      filter(Policy_Contract_Number == contract_id) %>%
                                      select(-matches("Policy_TPA", ignore.case = TRUE))
                              },
                              "life_values" = {
                                  life_values %>%
                                      filter(Life_Contract_Number == contract_id) %>%
                                      select(-matches("Life_TPA", ignore.case = TRUE))
                              },
                              "annuity_values" = {
                                  annuity_values %>%
                                      filter(Annuity_Contract_ID == contract_id)
                              },
                              data.frame(Message = "No detail data available")
        )

        # Clean and format the data
        if (nrow(detail_data) > 0 && "Message" %in% names(detail_data) == FALSE) {
            # Hide unwanted columns (all Role_, Name_, Agent_ columns)
            detail_data <- detail_data %>%
                select(-matches("^Role_|^Name_|^Agent_", ignore.case = TRUE))

            # Clean up specific values
            detail_data <- detail_data %>%
                mutate(across(everything(), ~case_when(
                    is.character(.x) & toupper(.x) %in% c("UNK", "UNKNOWN") ~ "Not Available",
                    is.character(.x) & .x == "" ~ "Not Available",
                    .x == "2999-12-31" ~ "Not Available",
                    .x == "1900-01-01" ~ "Not Available",
                    TRUE ~ as.character(.x)
                )))
        }
    }


    get_contract_names <- function(contract_id) {
        contract_parties <- get_contract_parties(contract_id) %>%
            filter(Role_Contract_ID == contract_id)



        # Try owner first, fallback to first person (same logic as contract summary)
        primary_person <- contract_parties %>% filter(party_type == "Owner") %>% slice(1)
        if(nrow(primary_person) == 0) {
            primary_person <- contract_parties %>% slice(1)
        }

        if(nrow(primary_person) == 0) return("No names found")

        info_summary <- paste0(
            primary_person$display_name,
            if_else(!is.na(primary_person$Name_DOB), paste0(" (DOB: ", primary_person$Name_DOB, ")"), ""),
            if_else(!is.na(primary_person$Name_Email), paste0(" | ", primary_person$Name_Email), "")
        )

        return(info_summary)
    }

    output$detailed_data_table <- DT::renderDataTable({
        selected_row <- selected_row_data()
        if (!is.null(selected_row)) {
            detail_data <- get_detail_data(selected_row)

            # Set different hidden columns based on activity type
            hidden_columns <- switch(selected_row$activity_type,
                                     "transactions" = c("Transaction_Number"),
                                     "claims" = c("Claims_Claim_ID"),
                                     "disbursements" = c("Disbursement_Number", "Disbursement_Name_ID", "Disbursement_Allocation_Percent"),
                                     "automated_activity" = c("Activity_Name_ID"),
                                     c()  # default: no hidden columns
            )

            dt_options <- list(pageLength = 10, scrollX = TRUE)

            # Only add columnDefs if there are columns to hide
            if (length(hidden_columns) > 0) {
                dt_options$columnDefs <- list(list(visible = FALSE, targets = hidden_columns))
            }

            dt_table <- DT::datatable(detail_data, options = dt_options, rownames = FALSE)
            format_dt_table(dt_table, detail_data)
        }
    })

    # Checklist management
    output$checklist_header <- renderText({
        if (input$review_mode == "activity") "Activity Review Checklist" else "Title Quality Review Checklist"
    })

    output$dynamic_checklist <- renderUI({
        selected_row <- selected_row_data()
        if (!is.null(selected_row)) {
            activity_type <- if (input$review_mode == "activity") selected_row$activity_type else "titles"
            checklist_data <- CHECKLISTS[[activity_type]] %||% CHECKLISTS$default
            weights <- CATEGORY_WEIGHTS[[activity_type]] %||% CATEGORY_WEIGHTS$default
            generate_checklist_ui(checklist_data, weights, "checklist_")
        }
    })

    # Scoring
    contract_score <- reactive({
        caSystem platformulate_unified_score("checklist_",
                                if (input$review_mode == "activity") selected_row_data()$activity_type else "titles",
                                input)
    })

    observeEvent(input$score_contract, {
        score_data <- contract_score()
        selected_row <- selected_row_data()

        if (!is.null(selected_row)) {


            status_msg <- if (score_data$pass) "PASSED" else "FAILED"
            showNotification(paste("Contract scored:", score_data$score, "% -", status_msg),
                             type = if (score_data$pass) "success" else "warning")
        }
    })

    output$contract_score_display <- renderText({
        score_data <- contract_score()
        status <- if (score_data$pass) "PASS" else "FAIL"

        category_text <- ""
        if (length(score_data$category_details) > 0) {
            for (category in names(score_data$category_details)) {
                details <- score_data$category_details[[category]]
                weighted_score <- round(score_data$category_scores[[category]], 1)
                category_text <- paste0(category_text, stringr::str_to_title(category), ": ",
                                        details$checked, "/", details$total, " (", details$percentage, "%) = ", weighted_score, " pts\n")
            }
        }

        paste("Overall Score:", score_data$score, "%\nStatus:", status, "\n\nCategory Breakdown:\n", category_text)
    })

    output$contract_summary <- renderText({
        selected_row <- selected_row_data()
        if (!is.null(selected_row)) {
            contract_id <- selected_row$contract_id

            tryCatch({
                # Get all roles for this contract
                all_roles <- agent_name_role_lookup %>%
                    filter(Role_Contract_ID == contract_id) %>%
                    filter(!grepl("rep", Role_Type, ignore.case = TRUE)) %>%
                    mutate(
                        display_name = case_when(
                            !is.na(Name_First_Name) & !is.na(Name_Legal_Name) &
                                Name_First_Name != "" & Name_Legal_Name != "" ~
                                paste(Name_First_Name, Name_Legal_Name),
                            !is.na(Name_Legal_Name) & Name_Legal_Name != "" ~ Name_Legal_Name,
                            TRUE ~ paste("ID:", Role_Name_ID)
                        ),
                        has_rider = !is.na(Role_Rider_Code) & Role_Rider_Code != "",
                        allocation_display = ifelse(!is.na(Role_Allocation_Percent),
                                                    paste0(Role_Allocation_Percent, "%"), "N/A"),
                        relationship_display = ifelse(!is.na(Role_Relationship_Code) & Role_Relationship_Code != -999,
                                                      Role_Relationship_Code, "N/A")
                    ) %>%
                    arrange(Role_Type, display_name)

                if (nrow(all_roles) == 0) {
                    return("No role information available for this contract")
                }

                # Build role details section
                role_details <- ""
                for (i in 1:nrow(all_roles)) {
                    role <- all_roles[i, ]

                    # Special case for "bene info on file"
                    if (!is.na(role$Name_Legal_Name) && tolower(role$Name_Legal_Name) == "bene info on file") {
                        role_details <- paste0(role_details, role$Role_Type, ": bene info on file\n")
                        next
                    }


                    # Skip allocation and relationship for org roles
                    if (tolower(role$Role_Type) == "org") {
                        role_line <- paste0(role$Role_Type, ": ", role$display_name)
                    } else {
                        # Build role line with non-N/A values only
                        role_parts <- c(paste0(role$Role_Type, ": ", role$display_name))

                        if (role$allocation_display != "N/A") {
                            role_parts <- c(role_parts, paste("Allocation:", role$allocation_display))
                        }

                        if (role$relationship_display != "N/A") {
                            role_parts <- c(role_parts, paste("Relationship:", role$relationship_display))
                        }

                        role_line <- paste(role_parts, collapse = " | ")
                    }

                    role_line <- paste(role_parts, collapse = " | ")

                    # Add rider info if present
                    if (role$has_rider) {
                        role_line <- paste0(role_line, " | Rider: ", role$Role_Rider_Code)
                    }

                    # Add agent organization if this is an agent role
                    if (is_agent_role(role$Role_Type) && !is.na(role$Agent_Organization_Name)) {
                        role_line <- paste0(role_line, " | Org: ", role$Agent_Organization_Name)
                    }

                    role_details <- paste0(role_details, role_line, "\n")
                }

                # Get policy and activity summary
                policy_info <- policies %>% filter(Policy_Contract_Number == contract_id) %>% slice(1)
                policy_summary <- if(nrow(policy_info) > 0) {
                    paste0(policy_info$Policy_Product_Description %||% "Unknown Product",
                           ifelse(!is.na(policy_info$Policy_Issue_Date),
                                  paste0(" (Issued: ", policy_info$Policy_Issue_Date, ")"), ""))
                } else "No Policy Info"

                # Activity counts
                trans_count <- nrow(transactions %>% filter(Transaction_Contract_Number == contract_id))
                disb_count <- nrow(disbursements %>% filter(Disbursement_Contract_Number == contract_id))
                claim_count <- nrow(claims %>% filter(Claims_Contract_Number == contract_id))

                # Check for any riders on this contract
                contract_riders <- all_roles %>% filter(has_rider) %>% pull(Role_Rider_Code) %>% unique()
                rider_summary <- if(length(contract_riders) > 0) {
                    paste0("\nRiders: ", paste(contract_riders, collapse = ", "))
                } else "\nRiders: None"

                # TPA sources
                tpa_sources <- all_roles %>% filter(!is.na(Role_TPA)) %>% pull(Role_TPA) %>% unique()
                tpa_summary <- if(length(tpa_sources) > 0) {
                    paste0("\nTPA Sources: ", paste(tpa_sources, collapse = ", "))
                } else ""

                # Check for agents (only show for comm rep or serv rep roles)
                agent_roles <- all_roles %>%
                    filter(is_agent_role(Role_Type)) %>%
                    select(display_name, Agent_Organization_Name) %>%
                    distinct()

                agent_summary <- if(nrow(agent_roles) > 0) {
                    agent_text <- agent_roles %>%
                        mutate(agent_info = paste0(display_name,
                                                   ifelse(!is.na(Agent_Organization_Name),
                                                          paste0(" (", Agent_Organization_Name, ")"), ""))) %>%
                        pull(agent_info) %>%
                        paste(collapse = ", ")
                    paste0("\nAgents: ", agent_text)
                } else ""

                formatted_amount <- ifelse(is.na(selected_row$amount) | selected_row$amount == 0,
                                           "$0.00", dollar(selected_row$amount, accuracy = 0.01))

                paste("Contract Summary:",
                      "\n--- Policy Info ---",
                      "\nProduct:", policy_summary,
                      rider_summary,
                      tpa_summary,
                      agent_summary,
                      "\n--- All Contract Roles ---",
                      "\n", role_details,
                      "\n--- Activity Summary ---",
                      "\nTransactions:", trans_count,
                      "\nDisbursements:", disb_count,
                      "\nClaims:", claim_count,
                      "\nLast Activity:", selected_row$cycle_date,
                      "\nAmount:", formatted_amount,
                      "\nDollar Risk:", selected_row$dollar_risk)

            }, error = function(e) {

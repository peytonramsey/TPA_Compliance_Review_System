# Business rule validators
is_valid_value <- function(value, field_type = "default") {
    if (is.na(value) || is.null(value) || value == "") return(FALSE)

    switch(field_type,
           "date" = value != "2999-12-31",
           "relationship" = value != -999,
           "gender" = value != "unk",
           TRUE
    )
}

get_display_name <- function(first_name, legal_name, name_type) {
    if (!is_valid_value(first_name) && is_valid_value(legal_name)) {
        return(legal_name) # Company/org name
    } else if (is_valid_value(first_name) && is_valid_value(legal_name)) {
        return(paste(first_name, legal_name)) # Person name
    }
    return(NA)
}

is_agent_role <- function(role_type) {
    ifelse(is.na(role_type) | is.null(role_type) | role_type == "",
           FALSE,
           tolower(role_type) %in% c("serv rep", "comm rep"))
}


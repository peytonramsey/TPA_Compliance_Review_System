            left_join(activity_amounts, by = c("contract_id", "activity_type", "original_id"))

        display_data <- history_with_amounts %>%
            select(`Contract ID` = contract_id, `Activity Type` = activity_type, `Review Date` = review_date,
                   `Amount` = amount, `Status` = review_status, `Quality Score` = quality_score, `Pass/Fail` = quality_pass, `Reviewed By` = reviewed_by, `Notes` = review_notes) %>%
            mutate(
                `Amount` = ifelse(is.na(`Amount`) | `Amount` == 0, "$0.00", dollar(`Amount`, accuracy = 0.01)),
                `Quality Score` = ifelse(is.na(`Quality Score`), "N/A", paste0(round(`Quality Score`, 1), "%")),
                `Pass/Fail` = ifelse(`Pass/Fail`, "PASS", "FAIL")
            ) %>%
            arrange(desc(`Review Date`))

        DT::datatable(display_data, options = list(pageLength = 25, scrollX = TRUE), rownames = FALSE, filter = 'top') %>%
            formatStyle("Pass/Fail", backgroundColor = styleEqual(c("PASS", "FAIL"), c("#d4edda", "#f8d7da")))
    })

    # Correspondence & Ad Hoc functionality
    output$correspondence_adhoc_dynamic_checklist <- renderUI({
        check_type <- input$correspondence_adhoc_check_type %||% "correspondence"
        checklist_data <- CHECKLISTS$correspondence_adhoc[[check_type]]

        if (is.null(checklist_data)) return(div("Select a check type"))

        weights <- setNames(rep(round(100 / length(checklist_data)), length(checklist_data)), names(checklist_data))
        generate_checklist_ui(checklist_data, weights, "correspondence_adhoc_checklist_")
    })

    correspondence_adhoc_score <- reactive({
        caSystem platformulate_unified_score("correspondence_adhoc_checklist_", "correspondence_adhoc", input)
    })

    output$correspondence_adhoc_score_display <- renderText({
        score_data <- correspondence_adhoc_score()
        status <- if (score_data$pass) "PASS" else "FAIL"

        category_text <- ""
        if (length(score_data$category_details) > 0) {
            for (category in names(score_data$category_details)) {
                details <- score_data$category_details[[category]]
                weighted_score <- round(score_data$category_scores[[category]], 1)
                category_text <- paste0(category_text, stringr::str_to_title(category), ": ",
                                        details$checked, "/", details$total, " (", details$percentage, "%) = ", weighted_score, " pts\n")
            }
        }

        paste("Overall Score:", score_data$score, "%\nStatus:", status, "\n\nCategory Breakdown:\n", category_text)
    })

    observeEvent(input$save_correspondence_adhoc, {
        req(input$correspondence_adhoc_contract_id, input$correspondence_adhoc_check_type)
        score_data <- correspondence_adhoc_score()

        review_record <- data.frame(
            contract_id = input$correspondence_adhoc_contract_id, activity_type = "correspondence_adhoc",
            original_id = paste("correspondence_adhoc", input$correspondence_adhoc_check_type, format(Sys.time(), "%Y%m%d_%H%M%S"), sep = "_"),
            cycle_date = Sys.Date(), review_status = input$correspondence_adhoc_status, quality_score = score_data$score,
            checklist_completed = score_data$checked, checklist_total = score_data$total, quality_pass = score_data$pass,
            review_notes = paste0("Check Type: ", input$correspondence_adhoc_check_type, " | ", input$correspondence_adhoc_notes),
            follow_up_actions = "", reviewed_by = input$correspondence_adhoc_reviewer, review_date = Sys.Date(),
            review_mode = "correspondence_adhoc", regulatory_score = NA, financial_score = NA, process_score = NA,
            category_scores = paste(names(score_data$category_scores), unlist(score_data$category_scores), sep = ":", collapse = ";"),
            stringsAsFactors = FALSE
        )

        app_state$saved_reviews <- save_review_to_parquet(review_record)

        showNotification("Correspondence & Ad Hoc review saved successfully!", type = "message")

        # Reset form
        form_resets <- list(
            correspondence_adhoc_contract_id = "",
            correspondence_adhoc_notes = ""
        )
        for(input_id in names(form_resets)) {
            if(grepl("notes", input_id)) {
                updateTextAreaInput(session, input_id, value = form_resets[[input_id]])
            } else {
                updateTextInput(session, input_id, value = form_resets[[input_id]])
            }
        }
        reset_checkboxes(session, "correspondence_adhoc_checklist_", 20)
    })


    output$correspondence_adhoc_review_table <- DT::renderDataTable({
        correspondence_reviews <- app_state$saved_reviews %>% filter(activity_type == "correspondence_adhoc")

        if (nrow(correspondence_reviews) == 0) {
            return(DT::datatable(data.frame(Message = "No correspondence & ad hoc reviews recorded"), rownames = FALSE))
        }

        display_data <- correspondence_reviews %>%
            mutate(
                check_type = case_when(
                    grepl("Check Type: correspondence", review_notes) ~ "Correspondence",
                    grepl("Check Type: adhoc", review_notes) ~ "Ad Hoc Review",
                    grepl("Check Type: other", review_notes) ~ "Other",
                    TRUE ~ "Unknown"
                ),
                notes_cleaned = gsub("^Check Type: [^|]+ \\| ", "", review_notes)
            ) %>%
            select(`Contract ID` = contract_id, `Check Type` = check_type, `Review Date` = review_date,
                   `Quality Score` = quality_score, `Status` = review_status, `Pass/Fail` = quality_pass,
                   `Reviewed By` = reviewed_by, `Notes` = notes_cleaned) %>%
            mutate(`Quality Score` = paste0(round(`Quality Score`, 1), "%"),
                   `Pass/Fail` = ifelse(`Pass/Fail`, "PASS", "FAIL")) %>%
            arrange(desc(`Review Date`))

        DT::datatable(display_data, options = list(pageLength = 25, scrollX = TRUE), rownames = FALSE) %>%
            formatStyle("Pass/Fail", backgroundColor = styleEqual(c("PASS", "FAIL"), c("#d4edda", "#f8d7da")))
    })
}

# Launch application
shinyApp(ui = ui, server = server)

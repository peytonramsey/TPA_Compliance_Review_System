# Unified data processing
create_full_activity_data <- function() {
    # Standardized processing for all activity types
    process_activity <- function(data, id_col, contract_col, date_col, type) {
        data %>%
            arrange(desc(!!sym(date_col))) %>%
            distinct(!!sym(id_col), .keep_all = TRUE) %>%
            mutate(
                activity_type = type,
                original_id = as.character(!!sym(id_col)),
                contract_id = !!sym(contract_col),
                cycle_date = !!sym(date_col)
            ) %>%
            select(contract_id, cycle_date, activity_type, original_id)
    }

    bind_rows(
        process_activity(transactions, "Transaction_Number", "Transaction_Contract_Number", "Transaction_Cycle_Date", "transactions"),
        process_activity(disbursements, "Disbursement_Number", "Disbursement_Contract_Number", "Disbursement_Cycle_Date", "disbursements"),
        claims %>%
            mutate(
                activity_type = "claims",
                original_id = as.character(Claims_Claim_ID),
                contract_id = Claims_Contract_Number,
                cycle_date = Claims_Cycle_Date
            ) %>%
            select(contract_id, cycle_date, activity_type, original_id),
        automated_activity %>% mutate(combined_id = paste(Activity_Contract_Number, row_number(), sep = "_")) %>%
            process_activity("combined_id", "Activity_Contract_Number", "Activity_Cycle_Date", "automated_activity"),
        process_activity(policies, "Policy_Contract_Number", "Policy_Contract_Number", "Policy_Cycle_Date", "policies"),
        annuity_values %>% mutate(temp_id = row_number()) %>%
            process_activity("temp_id", "Annuity_Contract_ID", "Annuity_Cycle_Date", "annuity_values"),
        life_values %>% mutate(temp_id = row_number()) %>%
            process_activity("temp_id", "Life_Contract_Number", "Life_Cycle_Date", "life_values")
    )
}

# Unified amount processing
add_dollar_amounts <- function(data, high_threshold, low_threshold) {
    amount_lookups <- list(
        transactions = transactions %>% distinct(Transaction_Number, .keep_all = TRUE) %>%
            select(original_id = Transaction_Number, amount = Transaction_Total_Dollar_Amount) %>%
            mutate(original_id = as.character(original_id), activity_type = "transactions") %>%
            distinct(original_id, activity_type, .keep_all = TRUE),

        disbursements = disbursements %>% distinct(Disbursement_Number, .keep_all = TRUE) %>%
            select(original_id = Disbursement_Number, amount = Disbursement_Gross_Amount) %>%
            mutate(original_id = as.character(original_id), activity_type = "disbursements") %>%
            distinct(original_id, activity_type, .keep_all = TRUE),

        claims = claims %>% distinct(Claims_Claim_ID, .keep_all = TRUE) %>%
            select(original_id = Claims_Claim_ID, amount = Claims_Benefit_Amount) %>%
            mutate(original_id = as.character(original_id), activity_type = "claims") %>%
            distinct(original_id, activity_type, .keep_all = TRUE),

        automated_activity = automated_activity %>%
            mutate(original_id = paste(Activity_Contract_Number, row_number(), sep = "_")) %>%
            distinct(original_id, .keep_all = TRUE) %>%
            select(original_id, amount = Activity_Amount) %>%
            mutate(activity_type = "automated_activity"),

        annuity_values = annuity_values %>% mutate(temp_id = row_number()) %>%
            select(original_id = temp_id, amount = Annuity_Net_Cash_Value) %>%
            mutate(original_id = as.character(original_id), activity_type = "annuity_values") %>%
            distinct(original_id, activity_type, .keep_all = TRUE),

        life_values = life_values %>% mutate(temp_id = row_number()) %>%
            select(original_id = temp_id, amount = Life_Face_Amount) %>%
            mutate(original_id = as.character(original_id), activity_type = "life_values") %>%
            distinct(original_id, activity_type, .keep_all = TRUE)
    )

    all_amounts <- bind_rows(amount_lookups)

    data %>%
        left_join(all_amounts, by = c("original_id", "activity_type")) %>%
        mutate(
            amount = coalesce(amount, 0),
            dollar_risk = case_when(
                amount >= high_threshold ~ "High Dollar",
                amount <= low_threshold & amount > 0 ~ "Low Dollar",
                TRUE ~ "Normal"
            )
        )
}

format_dt_table <- function(dt_table, data) {
    monetary_cols <- intersect(names(data), COLUMN_FORMATS$monetary)
    percentage_cols <- intersect(names(data), COLUMN_FORMATS$percentage)
    basis_points_cols <- intersect(names(data), COLUMN_FORMATS$basis_points)

    if (length(monetary_cols) > 0) {
        dt_table <- dt_table %>% formatCurrency(monetary_cols, currency = "$", digits = 2)
    }
    if (length(percentage_cols) > 0) {
        # Simply add % suffix - values already correct
        dt_table <- dt_table %>% formatString(percentage_cols, suffix = "%")
    }
    if (length(basis_points_cols) > 0) {
        dt_table <- dt_table %>% formatRound(basis_points_cols, digits = 0, mark = ",")
    }
    return(dt_table)
}

# Unified parquet operations
initialize_parquet <- function(parquet_path, extra_cols = NULL) {
    if (!file.exists(parquet_path)) {
        base_cols <- data.frame(
            contract_id = character(0), activity_type = character(0), original_id = character(0),
            cycle_date = as.Date(character(0)), review_status = character(0), quality_score = numeric(0),
            checklist_completed = integer(0), checklist_total = integer(0), quality_pass = logical(0),
            review_notes = character(0), follow_up_actions = character(0), reviewed_by = character(0),
            review_date = as.Date(character(0)), review_mode = character(0), regulatory_score = numeric(0),
            financial_score = numeric(0), process_score = numeric(0), category_scores = character(0),
            stringsAsFactors = FALSE
        )
        if (!is.null(extra_cols)) base_cols <- cbind(base_cols, extra_cols)
        write_parquet(base_cols, parquet_path)
        return(base_cols)
    }
    read_parquet(parquet_path)
}

load_saved_reviews <- function(parquet_path = CONFIG$parquet_path) {
    data <- initialize_parquet(parquet_path)
    if (nrow(data) > 0) {
        data$cycle_date <- as.Date(data$cycle_date)
        data$review_date <- as.Date(data$review_date)
        data$quality_pass <- as.logical(data$quality_pass)
    }
    data
}

save_review_to_parquet <- function(review_data, parquet_path = CONFIG$parquet_path) {
    existing_data <- load_saved_reviews(parquet_path)
    review_key <- paste(review_data$contract_id, review_data$activity_type, review_data$original_id, sep = "_")
    existing_keys <- paste(existing_data$contract_id, existing_data$activity_type, existing_data$original_id, sep = "_")

    if (review_key %in% existing_keys) {
        existing_data[which(existing_keys == review_key), ] <- review_data
    } else {
        existing_data <- rbind(existing_data, review_data)
    }
    write_parquet(existing_data, parquet_path)
    existing_data
}

merge_activity_with_reviews <- function(activity_data, saved_reviews) {
    if (nrow(saved_reviews) == 0) {
        return(activity_data %>%
                   mutate(review_status = "Pending Review", quality_score = NA_real_,
                          checklist_completed = NA_integer_, checklist_total = CONFIG$default_checklist_total,
                          quality_pass = FALSE, review_notes = "", follow_up_actions = "",
                          reviewed_by = "", review_date = as.Date(NA), review_mode = "activity",
                          regulatory_score = NA_real_, financial_score = NA_real_, process_score = NA_real_))
    }

    activity_data %>%
        left_join(saved_reviews %>% select(-cycle_date), by = c("contract_id", "activity_type", "original_id")) %>%
        mutate(
            review_status = coalesce(review_status, "Pending Review"),
            quality_score = coalesce(quality_score, NA_real_),
            checklist_completed = coalesce(checklist_completed, NA_integer_),
            checklist_total = coalesce(checklist_total, CONFIG$default_checklist_total),
            quality_pass = coalesce(quality_pass, FALSE),
            review_notes = coalesce(review_notes, ""),
            follow_up_actions = coalesce(follow_up_actions, ""),
            reviewed_by = coalesce(reviewed_by, ""),
            review_date = coalesce(review_date, as.Date(NA)),
            review_mode = coalesce(review_mode, "activity"),
            regulatory_score = coalesce(regulatory_score, NA_real_),
            financial_score = coalesce(financial_score, NA_real_),
            process_score = coalesce(process_score, NA_real_)
        )
}


# Add after the merge_activity_with_reviews function
get_contract_parties <- function(contract_id) {
    contract_roles <- agent_name_role_lookup %>%
        filter(Role_Contract_ID == contract_id) %>%
        mutate(
            display_name = case_when(
                !is.na(Name_First_Name) & !is.na(Name_Legal_Name) &
                    Name_First_Name != "" & Name_Legal_Name != "" ~
                    paste(Name_First_Name, Name_Legal_Name),
                !is.na(Name_Legal_Name) & Name_Legal_Name != "" ~ Name_Legal_Name,
                TRUE ~ paste("ID:", Role_Name_ID)
            ),
            party_type = case_when(
                grepl("OWN", Role_Type, ignore.case = TRUE) ~ "Owner",
                grepl("AGENT|PRODUCER", Role_Type, ignore.case = TRUE) ~ "Agent",
                TRUE ~ "Other"
            ),
            age = ifelse(!is.na(Name_DOB),
                         as.numeric(difftime(Sys.Date(), as.Date(Name_DOB), units = "days")) %/% 365.25,
                         NA)
        )
    return(contract_roles)
}

# Unified scoring system
caSystem platformulate_unified_score <- function(input_prefix, activity_type, input_list) {
    checklist_data <- CHECKLISTS[[activity_type]] %||% CHECKLISTS$default
    weights <- CATEGORY_WEIGHTS[[activity_type]] %||% CATEGORY_WEIGHTS$default

    item_counter <- 0
    category_scores <- list()
    category_details <- list()

    for (category in names(checklist_data)) {
        items <- checklist_data[[category]]
        category_checked <- 0

        for (i in 1:length(items)) {
            item_counter <- item_counter + 1
            if (!is.null(input_list[[paste0(input_prefix, item_counter)]]) &&
                input_list[[paste0(input_prefix, item_counter)]]) {
                category_checked <- category_checked + 1
            }
        }

        category_pct <- if (length(items) > 0) (category_checked / length(items)) * 100 else 0
        category_weighted_score <- (category_pct * weights[[category]]) / 100

        category_scores[[category]] <- category_weighted_score
        category_details[[category]] <- list(checked = category_checked, total = length(items), percentage = round(category_pct, 1))
    }

    total_score <- round(sum(unlist(category_scores)), 1)
    pass_status <- total_score >= CONFIG$quality_pass_threshold

    list(score = total_score, checked = sum(sapply(category_details, function(x) x$checked)),
         total = sum(sapply(category_details, function(x) x$total)), pass = pass_status,
         category_details = category_details, category_scores = category_scores)
}


check_data_freshness <- function() {
    if (!file.exists(CONFIG$timestamp_file)) return(FALSE)
    last_update <- readLines(CONFIG$timestamp_file)[1]
    last_update_time <- as.POSIXct(last_update)
    hours_since_update <- as.numeric(difftime(Sys.time(), last_update_time, units = "hours"))
    return(hours_since_update < CONFIG$data_refresh_hours)
}

load_data <- function() {
    if (!exists("transactions") || !exists("disbursements") || !check_data_freshness()) {
        if (file.exists(CONFIG$data_file)) {
            load(CONFIG$data_file, envir = .GlobalEnv)
            required_objects <- c("transactions", "disbursements", "claims", "automated_activity", "policies", "annuity_values", "life_values", "agent_name_role_lookup")
            missing_objects <- required_objects[!sapply(required_objects, exists)]
            if (length(missing_objects) > 0) stop("Missing required data objects: ", paste(missing_objects, collapse = ", "))
        } else {
            stop("Data file not found: ", CONFIG$data_file)
        }
    }
}

get_prior_month_range <- function(current_date = Sys.Date()) {
    first_day_current <- floor_date(current_date, "month")
    first_day_prior <- first_day_current - months(1)
    last_day_prior <- ceiling_date(first_day_prior, "month") - days(1)
    list(start = first_day_prior, end = last_day_prior)
}

generate_checklist_ui <- function(checklist_data, weights, input_prefix) {
    if (is.null(checklist_data)) return(div("No checklist data available"))

    category_ui <- list()
    item_counter <- 0

    for (category in names(checklist_data)) {
        items <- checklist_data[[category]]
        category_weight <- weights[[category]]
        display_category <- stringr::str_to_title(gsub("_", " ", category))

        # Category header
        category_ui <- append(category_ui, list(
            h5(paste(display_category, "Items (", category_weight, "% of total score)"),
               style = "color: #337ab7; margin-top: 20px;")
        ))

        # Category items
        for (i in 1:length(items)) {
            item_counter <- item_counter + 1
            category_ui <- append(category_ui, list(
                div(style = "margin-bottom: 8px; margin-left: 15px;",
                    checkboxInput(paste0(input_prefix, item_counter), label = items[i], value = FALSE))
            ))
        }
    }
    div(category_ui, hr())
}

